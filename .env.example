# ─── Database ──────────────────────────────────────────────────────────────────
# Use either a direct PostgreSQL connection string or Supabase connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/athleteai
# OR use Supabase:
# SUPABASE_DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard: Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=athlete-media

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
# Signing secret from Stripe webhook configuration
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Price IDs from Stripe dashboard -> Products
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_ELITE_PRICE_ID=price_xxxxxxxxxxxxx

# ─── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=your-jwt-secret-here-change-in-production

# ─── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
CLIENT_URL=http://localhost:3000
BASE_PATH=/