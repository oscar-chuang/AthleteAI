# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway Postgres, etc.)
DATABASE_URL=postgres://user:password@host:5432/dbname

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Long random string — generate with: openssl rand -hex 64
JWT_SECRET=your-jwt-secret-here

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Storage (Cloudflare R2) ──────────────────────────────────────────────────
# From Cloudflare dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=athleteai-storage

# ─── Mobile app ───────────────────────────────────────────────────────────────
# URL of the deployed API server (used by the Expo app outside Replit)
EXPO_PUBLIC_API_URL=https://your-railway-app.up.railway.app
