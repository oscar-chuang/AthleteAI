# ─── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=change-me-to-a-long-random-string
ANTHROPIC_API_KEY=sk-ant-...

# ─── Object Storage (Cloudflare R2) ──────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── Redis (optional — enables caching, rate-limiting, distributed locks, job queue)
# Recommended: Upstash Redis (https://upstash.com) — free tier available.
# Format: redis://default:<password>@<host>:<port>
# When absent the server starts normally but without caching/rate-limiting/queue.
REDIS_URL=

# ─── Connection pool ──────────────────────────────────────────────────────────
# Maximum Postgres connections in the pool (default: 10).
DB_POOL_MAX=10

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
