{
  "expo": {
    "name": "AthleteAI",
    "slug": "athleteai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "athleteai",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.athleteai.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "AthleteAI needs access to your photo library to select training videos for analysis.",
        "NSCameraUsageDescription": "AthleteAI needs camera access to record your training sessions.",
        "NSMicrophoneUsageDescription": "AthleteAI needs microphone access when recording training videos."
      }
    },
    "android": {
      "package": "com.athleteai.app",
      "versionCode": 1,
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "AthleteAI needs access to your photo library to select training videos.",
          "cameraPermission": "AthleteAI needs camera access to record training sessions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
